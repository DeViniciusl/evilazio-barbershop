{
  "name": "evilazio-barbershop",
  "version": "1.0.0",
  "description": "Site simples com agendamento para a Evilazio Barbershop",
  "main": "server.js",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "node server.js",
    "dev": "node --env-file=.env server.js",
    "start:enhanced": "node --env-file=.env server-enhanced.js",
    "dev:enhanced": "node --watch --env-file=.env server-enhanced.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "migrate": "node scripts/migrate.js"
  },
  "dependencies": {
    "express": "^4.18.0",
    "express-rate-limit": "^7.0.0",
    "helmet": "^7.0.0",
    "pg": "^8.11.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.3.0",
    "sharp": "^0.32.0",
    "aws-sdk": "^2.1500.0",
    "speakeasy": "^2.0.0",
    "qrcode": "^1.5.3"
  },
  "devDependencies": {
    "jest": "^29.0.0",
    "supertest": "^6.3.0"
  }
}
