# App Configuration
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://seu-dominio.com
APP_TIMEZONE=America/Fortaleza
MAX_JSON_BODY_SIZE=100kb

# Banco de Dados (Railway fornecerá DATABASE_URL automaticamente)
# Se usar localmente, configure com:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/barbershop
# Ou as variáveis individuais:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=seu_usuario
# PGPASSWORD=sua_senha
# PGDATABASE=barbershop

# JWT Tokens (IMPORTANTE: Gerar strings aleatórios em produção!)
# Gerar com: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
REFRESH_TOKEN_SECRET=your-super-secret-refresh-token-key-change-this-in-production

# Admin Configuration
ADMIN_EMAIL=admin@evilazio.local
ADMIN_PASSWORD=mude_para_uma_senha_muito_segura_aqui_minimo_12_caracteres
RESET_ADMIN_PASSWORD_ON_BOOT=false

# AWS S3 Configuration (opcional, para uploads de imagens)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_S3_BUCKET=evilazio-barbershop-images

# Email Configuration (opcional, para notificações)
EMAIL_FROM=noreply@evilazio.local
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Sessão
SESSION_TTL_MS=43200000
SESSION_SWEEP_INTERVAL_MS=300000
MAX_ACTIVE_SESSIONS=5000

# ⚠️ IMPORTANTE:
# - Este é um sistema de AGENDAMENTO SEM PAGAMENTO ONLINE
# - O pagamento é realizado PRESENCIALMENTE no local
# - Não há integração com APIs de pagamento (Mercado Pago, Stripe, etc)
# - Nunca commite este arquivo com dados reais (use .gitignore)
# - SEMPRE use valores seguros para JWT_SECRET e REFRESH_TOKEN_SECRET em produção
