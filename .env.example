# ============================================================================
# CONFIGURAÇÃO DO PROJETO - Evilazio Barbershop
# ============================================================================

# NODE ENVIRONMENT
NODE_ENV=development
PORT=3000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================

# Opção 1: URL completa (Railway, Heroku, etc)
DATABASE_URL=postgresql://user:password@localhost:5432/evilazio_barbershop

# Opção 2: Variáveis individuais (PostgreSQL)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=evilazio_barbershop

# ============================================================================
# SECURITY & JWT
# ============================================================================

# Gerar com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=sua-secret-super-seguro-32-caracteres-aleatorios
REFRESH_TOKEN_SECRET=seu-refresh-secret-super-seguro-32-caracteres

# Admin padrão (criado na inicialização)
ADMIN_EMAIL=admin@barbershop.local
ADMIN_PASSWORD=SenhaAdminForte123!@#

# ============================================================================
# AWS S3 (Para upload de imagens)
# ============================================================================

AWS_ACCESS_KEY_ID=sua-access-key-id
AWS_SECRET_ACCESS_KEY=sua-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET=evilazio-images

# ============================================================================
# TIMEZONE
# ============================================================================

APP_TIMEZONE=America/Fortaleza

# ============================================================================
# SESSION & RATE LIMITING
# ============================================================================

MAX_ACTIVE_SESSIONS=5000
SESSION_TTL_MS=43200000  # 12 horas
SESSION_SWEEP_INTERVAL_MS=300000  # 5 minutos
MAX_JSON_BODY_SIZE=10mb

# ============================================================================
# EMAIL (Opcional - para notificações de agendamento)
# ============================================================================

EMAIL_PROVIDER=sendgrid
SENDGRID_API_KEY=seu-sendgrid-api-key
SENDGRID_FROM_EMAIL=noreply@evilazio.com

# Alternativa: SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu-email@gmail.com
SMTP_PASSWORD=sua-senha-app

# ============================================================================
# IMPORTANTE
# ============================================================================
# - Este é um sistema SEM PAGAMENTO ONLINE
# - O pagamento é PRESENCIAL no local
# - Nunca commite este arquivo com dados reais (use .gitignore)
# - SEMPRE use valores seguros para JWT_SECRET e REFRESH_TOKEN_SECRET em produção
