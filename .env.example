# App
NODE_ENV=production
PORT=3000
APP_BASE_URL=https://seu-dominio.com
APP_TIMEZONE=America/Fortaleza
MAX_JSON_BODY_SIZE=100kb

# Banco de Dados (Railway fornecerá DATABASE_URL automaticamente)
# Se usar localmente, configure com:
# DATABASE_URL=postgresql://usuario:senha@localhost:5432/barbershop
# Ou as variáveis individuais:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=seu_usuario
# PGPASSWORD=sua_senha
# PGDATABASE=barbershop

# Segurança e Admin
# IMPORTANTE: Mude ADMIN_PASSWORD para uma senha forte (mínimo 12 caracteres em produção)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=mude_para_uma_senha_muito_segura_aqui
RESET_ADMIN_PASSWORD_ON_BOOT=false

# Sessão
SESSION_TTL_MS=43200000
SESSION_SWEEP_INTERVAL_MS=300000
MAX_ACTIVE_SESSIONS=5000

# ⚠️ IMPORTANTE:
# - Este é um sistema de AGENDAMENTO SEM PAGAMENTO ONLINE
# - O pagamento é realizado PRESENCIALMENTE no local
# - Não há integração com APIs de pagamento (Mercado Pago, Stripe, etc)
# - Nunca commite este arquivo com dados reais (use .gitignore)
